# Server
NODE_ENV=development
PORT=4000

# Firebase
FIREBASE_PROJECT_ID=petholo-app
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=petholo-app.appspot.com
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# S3 / MinIO Storage
STORAGE_PROVIDER=local
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=petholo-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# CORS
CORS_ORIGIN=http://localhost:3000

# AI Mock 모드 (true: API 키 없이 프로필 생성 플로우 테스트)
USE_MOCK_AI=false

# AI APIs (Stubs)
NANOBANANA_API_URL=https://api.nanobanana.ai
NANOBANANA_API_KEY=your-nanobanana-key
KLING_API_URL=https://api.kling.ai
KLING_API_KEY=your-kling-key

# Cafe24 OAuth & Webhook
# Cafe24 개발자센터(https://developers.cafe24.com)에서 앱 등록 후 발급
CAFE24_MALL_ID=coreflow5103
CAFE24_CLIENT_ID=(Cafe24 앱 등록 후 발급)
CAFE24_CLIENT_SECRET=(Cafe24 앱 등록 후 발급)
CAFE24_REDIRECT_URI=https://[도메인]/cafe24/callback
CAFE24_WEBHOOK_SECRET=(Cafe24 웹훅 시크릿)

# 상품 ID 기반 판별 (쉼표 구분)
# 아크릴 세트 상품번호 목록 (카페24 product_no)
ACRYLIC_SET_PRODUCT_IDS=101,102

# 웹훅 상품ID → 타입 매핑 (productId:TYPE 쉼표 구분)
# TYPE: FULL_SET, CREDIT_120, CREDIT_40
CAFE24_PRODUCT_MAP=100:FULL_SET,200:CREDIT_120,300:CREDIT_40
