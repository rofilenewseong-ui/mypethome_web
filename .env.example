# ============================================
# PetHolo Environment Variables
# 이 파일을 .env로 복사한 후 값을 채우세요
# cp .env.example apps/api/.env
# ============================================

# Server
NODE_ENV=development
PORT=4000

# Firebase
FIREBASE_PROJECT_ID=mypethome-e117c
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=petholo-app.appspot.com
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# JWT
JWT_SECRET=change-this-in-production
JWT_REFRESH_SECRET=change-this-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# S3 / MinIO Storage (optional)
STORAGE_PROVIDER=firebase
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=petholo-uploads
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# CORS
CORS_ORIGIN=http://localhost:3000

# AI APIs
NANOBANANA_API_URL=https://api.nanobanana.ai
NANOBANANA_API_KEY=
KLING_API_URL=https://api.kling.ai
KLING_API_KEY=

# Cafe24
CAFE24_WEBHOOK_SECRET=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
